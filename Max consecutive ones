#include <iostream>
using namespace std;

int main()
{
    int n;
    cout << "Enter size of array: ";
    cin >> n;

    int arr[n];

    cout << "Enter elements (0 and 1): ";
    for(int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }

    int count = 0;
    int maxCount = 0;

    for(int i = 0; i < n; i++)
    {
        if(arr[i] == 1)
        {
            count++;
            if(count > maxCount)
                maxCount = count;
        }
        else
        {
            count = 0;
        }
    }

    cout << "Max consecutive ones: " << maxCount;

    return 0;
}
