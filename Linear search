#include <iostream>
using namespace std;

int main(){
  int a[5] = {10,20,30,40,50};
  int find = 20;
  int flag = 0;

  for (int i=0;i<5;i++){
    if(a[i] == find){
      cout<<"Found at index:"<<i<<endl;
      flag = 1;
      break;
    }
  }
  if(flag == 0){
    cout<<"Not found"<<endl;
  }
  return 0;
}
